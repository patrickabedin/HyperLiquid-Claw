[Unit]
Description=HyperLiquid MCP SSE Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/hyperliquid-mcp
Environment=PATH=/opt/hyperliquid-mcp/venv/bin
ExecStart=/opt/hyperliquid-mcp/venv/bin/uvicorn app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
